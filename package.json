{
  "name": "asuka",
  "version": "0.2.0",
  "description": "Asuka - Desktop floating bubble command launcher",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "node-gyp rebuild --directory=native",
    "build:native": "node-gyp rebuild --directory=native",
    "dev": "npm run build:native && electron-vite dev",
    "build": "npm run build:native && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit --project tsconfig.web.json && vue-tsc --noEmit --project tsconfig.node.json",
    "lint": "eslint . && npm run typecheck",
    "lint:fix": "eslint . --fix",
    "package": "electron-vite build && electron-builder --win zip"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "esbuild": "^0.21.5",
    "node-addon-api": "^8.8.0",
    "vue": "^3.4.38"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.1.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "node-gyp": "^10.3.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.3",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.29"
  },
  "build": {
    "appId": "com.asuka.app",
    "productName": "Asuka",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "native/build/Release/*.node",
      "resources/**/*",
      "types/**/*",
      "package.json"
    ],
    "asar": false,
    "win": {
      "target": "zip",
      "artifactName": "Asuka-${version}-win32-x64.zip"
    }
  }
}
